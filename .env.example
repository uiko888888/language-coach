# Choose deepl or libretranslate.
TRANSLATION_PROVIDER=deepl

# DeepL API Free: create your own key and keep it in .env.local only.
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Free self-hosted alternative. Example: http://127.0.0.1:5000
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# Optional semantic output feedback through an OpenAI-compatible chat-completions endpoint.
# The current task source and learner answer are sent only after the user clicks to request feedback.
OUTPUT_AI_PROVIDER=openai-compatible
OUTPUT_AI_API_URL=https://api.openai.com/v1/chat/completions
OUTPUT_AI_API_KEY=
OUTPUT_AI_MODEL=

# Optional user-triggered speaking transcription through an OpenAI-compatible endpoint.
# Recorded audio stays local unless the user explicitly requests transcription.
SPEECH_TRANSCRIPTION_PROVIDER=openai-compatible
SPEECH_TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
SPEECH_TRANSCRIPTION_API_KEY=
SPEECH_TRANSCRIPTION_MODEL=

# Optional FSRS 6.3.1 scheduler. Keep disabled until migration and replay tests pass.
LANGUAGE_COACH_FSRS=0
FSRS_DESIRED_RETENTION=0.90
