# Choose deepl or libretranslate.
TRANSLATION_PROVIDER=deepl

# DeepL API Free: create your own key and keep it in .env.local only.
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Free self-hosted alternative. Example: http://127.0.0.1:5000
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
